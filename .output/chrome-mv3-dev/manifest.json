{
  "manifest_version": 3,
  "name": "Vocabify",
  "description": "Turn browsing into passive vocabulary learning",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "contextMenus",
    "scripting",
    "tabs"
  ],
  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "MacCtrl+Shift+T"
      },
      "description": "Translate selected word with Vocabify"
    },
    "wxt:reload-extension": {
      "description": "Reload the extension during development",
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  },
  "host_permissions": [
    "https://api.mymemory.translated.net/*",
    "https://libretranslate.com/*",
    "https://translate.googleapis.com/*",
    "https://api.datamuse.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://www.youtube.com/*",
    "<all_urls>",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Vocabify",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content-scripts/content.css"
      ],
      "use_dynamic_url": true,
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost:3000; object-src 'self';",
    "sandbox": "script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3000; sandbox allow-scripts allow-forms allow-popups allow-modals; child-src 'self';"
  }
}